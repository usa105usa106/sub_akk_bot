TELEGRAM_BOT_TOKEN=
BOT_VERSION=0126
DEFAULT_EXCHANGE=mexc
DEFAULT_AI_PROVIDER=openai
DEFAULT_OPENAI_MODEL=gpt-5.4-mini
# 0 = /testai uses only the key saved by /setopenai. Set 1 to allow Railway OPENAI_API_KEY fallback.
OPENAI_ENV_FALLBACK=0
OLLAMA_MODELS=llama3.1:8b,deepseek-r1:8b
DEFAULT_MODEL=llama3.1:8b
DEFAULT_RISK_PERCENT=1
DEFAULT_LEVERAGE=5
DEFAULT_MIN_SCORE=80
DEFAULT_SCANNER_SIZE=100
DEFAULT_TOP_LIMIT=5
DEFAULT_AUTO_SCANNER_INTERVAL=off
DEFAULT_STRUCTURAL_MODE=off
DEFAULT_EXTENDED_TP_ENABLED=on
DEFAULT_EXTENDED_TP_MIN_CONFIDENCE=80
DEFAULT_EXTENDED_TP_RR=4
DEFAULT_STOP_ALL_ENABLED=off
DEFAULT_POSITION_SYNC_ENABLED=off
DEFAULT_POSITION_SYNC_INTERVAL=300
DEFAULT_STRICT_AI_MODE=on

DEFAULT_LIVE_TRADE_MANAGER_ENABLED=off

OLLAMA_KEEP_ALIVE=10m

AI_MAX_CONCURRENT=1
AI_APPROVAL_TOP_LIMIT=5
AI_CHAT_NUM_PREDICT=128
AI_APPROVAL_NUM_PREDICT=120

# MEXC support recommendation: max 4 requests within 2 seconds.
SCAN_MAX_CONCURRENT=5
SCAN_REQUEST_PAUSE=0.55

# Hard timeout for one coin scan, prevents full scan/autopilot from hanging on one bad MEXC/CCXT request.
SCAN_SYMBOL_TIMEOUT=12

# Memory optimization
MAX_OHLCV_LIMIT=160
SCAN_GC_EVERY=25
MAX_LIQUIDITY_CACHE=300
MAX_INSTITUTIONAL_CACHE=300

# Market metadata loaded once and reused; prevents repeated load_markets memory/API churn.
MARKETS_CACHE_TTL=21600
MAX_LAST_SCAN_RESULTS=25
MAX_AI_CONFIRMED_RESULTS=25
# Fast menu ping timeout only (does not affect trading scan timeout)
EXCHANGE_PING_TIMEOUT_SEC=2.0
EXCHANGE_PING_TIMEOUT_MS=2000

# CCXT network timeout for exchange calls. Keeps hung requests from blocking scanner threads too long.
EXCHANGE_TIMEOUT_MS=8000
